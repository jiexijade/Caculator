<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- 1. 顶部高级感标题栏 -->
    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        app:navigationIcon="@drawable/ic_menu"
        app:contentInsetStartWithNavigation="8dp"
        android:elevation="2dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="单位换算"
                android:textColor="#2C3E50"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="速度换算"
                android:textColor="#7F8C8D"
                android:textSize="14sp" />
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- 2. 可滚动的上半部分 (长度换算卡片) -->
    <!-- layout_height="0dp" 和 layout_weight="1" 让它占满除键盘外的所有剩余空间 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 顶部：从原始单位 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="源速度"
                        android:textSize="14sp"
                        android:textColor="#7F8C8D"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/edit_text_premium"
                        android:paddingHorizontal="12dp">

                        <EditText
                            android:id="@+id/etLengthFrom"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:hint="0"
                            android:textColorHint="#A0AAB5"
                            android:textColor="#2C3E50"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:background="@null" />

                        <View android:layout_width="1dp" android:layout_height="24dp" android:background="#E0E5EC" android:layout_marginHorizontal="8dp"/>

                        <Spinner
                            android:id="@+id/spinnerLengthFrom"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:minWidth="80dp" />
                    </LinearLayout>

                    <!-- 中间：包含交换按钮的分割线 -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="20dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F2F5"
                            android:layout_gravity="center_vertical" />

                        <!-- 沉浸式转换按钮 -->
                        <ImageButton
                            android:id="@+id/btnSwapLength"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_swap_vert"
                            app:tint="#5A6573"
                            android:background="@drawable/btn_op_premium"
                            android:elevation="0dp" />
                    </FrameLayout>

                    <!-- 底部：到目标单位 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="目标速度"
                        android:textSize="14sp"
                        android:textColor="#7F8C8D"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/edit_text_premium"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:id="@+id/tvLengthTo"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="0"
                            android:textColor="#788CA1"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:gravity="center_vertical" />

                        <View android:layout_width="1dp" android:layout_height="24dp" android:background="#E0E5EC" android:layout_marginHorizontal="8dp"/>

                        <Spinner
                            android:id="@+id/spinnerLengthTo"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:minWidth="80dp" />
                    </LinearLayout>

                    <!-- 常用快捷入口 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✧ 常用换算"
                        android:textSize="14sp"
                        android:textColor="#788CA1"
                        android:textStyle="bold"
                        android:layout_marginTop="28dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnSpeed1msToKmh"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="1m/s = 3.6km/h"
                            android:textSize="11sp"
                            android:textColor="#5A6573"
                            android:textAllCaps="false"
                            android:background="@drawable/btn_op_premium"
                            app:backgroundTint="@null"
                            android:stateListAnimator="@null"/>

                        <Button
                            android:id="@+id/btnSpeed1kmhToMs"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="1km/h ≈ 0.28m/s"
                            android:textSize="11sp"
                            android:textColor="#5A6573"
                            android:textAllCaps="false"
                            android:background="@drawable/btn_op_premium"
                            app:backgroundTint="@null"
                            android:stateListAnimator="@null"/>

                        <Button
                            android:id="@+id/btnSpeed1mphToKmh"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="1mph ≈ 1.61km/h"
                            android:textSize="11sp"
                            android:textColor="#5A6573"
                            android:textAllCaps="false"
                            android:background="@drawable/btn_op_premium"
                            app:backgroundTint="@null"
                            android:stateListAnimator="@null"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- 3. 固定的下半部分 (数字键盘区) -->
    <!-- 移除出 ScrollView，它将永久固定在屏幕底部 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#F5F6F8">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="4"
                android:padding="12dp">

                <!-- 第一行：7, 8, 9 -->
                <Button
                    android:id="@+id/btnUnit7"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="7"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnUnit8"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="8"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnUnit9"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="9"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <!-- 第二行：4, 5, 6 -->
                <Button
                    android:id="@+id/btnUnit4"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="4"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnUnit5"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="5"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnUnit6"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="6"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <!-- 第三行：1, 2, 3 -->
                <Button
                    android:id="@+id/btnUnit1"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="1"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnUnit2"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="2"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnUnit3"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="3"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <!-- 第四行：. , 0, DEL -->
                <Button
                    android:id="@+id/btnUnitDot"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="."
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnUnit0"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="0"
                    android:textSize="26sp"
                    android:textColor="#3D4045"
                    android:background="@drawable/btn_num_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnUnitDEL"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="DEL"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_eq_premium"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />
            </GridLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>