<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- 主界面内容 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8F9FA">

        <!-- 1. 顶部高级感标题栏（带抽屉菜单入口） -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FFFFFF"
            app:navigationIcon="@drawable/ic_menu"
            app:contentInsetStartWithNavigation="8dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="复数计算器"
                android:textSize="20sp"
                android:textColor="#2C3E50"
                android:textStyle="bold" />
        </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. 复数 A 卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="复数 A"
                        android:textSize="16sp"
                        android:textColor="#7F8C8D"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A ="
                            android:textSize="18sp"
                            android:textColor="#2C3E50"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp" />

                        <EditText
                            android:id="@+id/etComplexAReal"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:hint="实部"
                            android:textColorHint="#A0AAB5"
                            android:textColor="#2C3E50"
                            android:inputType="numberDecimal|numberSigned"
                            android:background="@drawable/edit_text_premium"
                            android:gravity="center"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+"
                            android:textSize="18sp"
                            android:textColor="#7F8C8D"
                            android:layout_marginHorizontal="8dp" />

                        <EditText
                            android:id="@+id/etComplexAImag"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:hint="虚部"
                            android:textColorHint="#A0AAB5"
                            android:textColor="#2C3E50"
                            android:inputType="numberDecimal|numberSigned"
                            android:background="@drawable/edit_text_premium"
                            android:gravity="center"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="i"
                            android:textSize="20sp"
                            android:textStyle="italic"
                            android:textColor="#7F8C8D"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 2. 复数 B 卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="复数 B"
                        android:textSize="16sp"
                        android:textColor="#7F8C8D"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="B ="
                            android:textSize="18sp"
                            android:textColor="#2C3E50"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp" />

                        <EditText
                            android:id="@+id/etComplexBReal"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:hint="实部"
                            android:textColorHint="#A0AAB5"
                            android:textColor="#2C3E50"
                            android:inputType="numberDecimal|numberSigned"
                            android:background="@drawable/edit_text_premium"
                            android:gravity="center"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+"
                            android:textSize="18sp"
                            android:textColor="#7F8C8D"
                            android:layout_marginHorizontal="8dp" />

                        <EditText
                            android:id="@+id/etComplexBImag"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:hint="虚部"
                            android:textColorHint="#A0AAB5"
                            android:textColor="#2C3E50"
                            android:inputType="numberDecimal|numberSigned"
                            android:background="@drawable/edit_text_premium"
                            android:gravity="center"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="i"
                            android:textSize="20sp"
                            android:textStyle="italic"
                            android:textColor="#7F8C8D"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. 双复数运算 卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="四则与幂运算"
                        android:textSize="16sp"
                        android:textColor="#7F8C8D"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:paddingHorizontal="4dp"/>

                    <!-- 使用 margin=4dp 来拉开按键间距，增加呼吸感 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button android:id="@+id/btnComplexAdd" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="A + B" android:textColor="#5A6573" android:textSize="16sp" android:textAllCaps="false" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                        <Button android:id="@+id/btnComplexSubtract" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="A - B" android:textColor="#5A6573" android:textSize="16sp" android:textAllCaps="false" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button android:id="@+id/btnComplexMultiply" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="A × B" android:textColor="#5A6573" android:textSize="16sp" android:textAllCaps="false" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                        <Button android:id="@+id/btnComplexDivide" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="A ÷ B" android:textColor="#5A6573" android:textSize="16sp" android:textAllCaps="false" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etPowerN"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:hint="输入n次幂"
                            android:textColorHint="#A0AAB5"
                            android:textColor="#2C3E50"
                            android:inputType="numberDecimal|numberSigned"
                            android:background="@drawable/edit_text_premium"
                            android:gravity="center"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <Button android:id="@+id/btnComplexPower" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="A^n (幂运算)" android:textColor="#5A6573" android:textSize="15sp" android:textAllCaps="false" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 4. 单复数属性与格式转换 卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="属性与格式转换"
                        android:textSize="16sp"
                        android:textColor="#7F8C8D"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:paddingHorizontal="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button android:id="@+id/btnConjugate" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="共轭复数" android:textColor="#5A6573" android:textSize="15sp" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                        <Button android:id="@+id/btnComplexConjugate" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="共轭(次)" android:textColor="#5A6573" android:textSize="15sp" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                        <Button android:id="@+id/btnArgument" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="求幅角" android:textColor="#5A6573" android:textSize="15sp" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button android:id="@+id/btnToPolar" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="→ 极坐标" android:textColor="#5A6573" android:textSize="15sp" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                        <Button android:id="@+id/btnToRectangular" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:text="→ 代数式" android:textColor="#5A6573" android:textSize="15sp" android:background="@drawable/btn_op_premium" app:backgroundTint="@null" android:stateListAnimator="@null"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 5. 最终结果展示区 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="计算结果"
                            android:textColor="#2C3E50"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- 清除按钮融合在结果标题栏右侧，视觉更聚合 -->
                        <Button
                            android:id="@+id/btnComplexClear"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="16dp"
                            android:text="清空"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/btn_eq_premium"
                            app:backgroundTint="@null"
                            android:stateListAnimator="@null"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F2F5"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvComplexResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingVertical="16dp"
                        android:text="0 + 0i"
                        android:textColor="#788CA1"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
    </LinearLayout>

    <!-- 导航抽屉：与主计算器一致，可切换到各功能页 -->
    <FrameLayout
        android:id="@+id/navDrawer"
        android:layout_width="@dimen/nav_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/nav_drawer_bg"
        android:elevation="8dp">

        <include
            android:id="@+id/navDrawerContent"
            layout="@layout/nav_drawer_content" />
    </FrameLayout>
</androidx.drawerlayout.widget.DrawerLayout>